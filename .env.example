# Vighna Environment Variables Example
# Duplicate this file to .env and fill in your keys

# Groq Cloud API Key (Required for AI features)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Picovoice Porcupine Access Key (Optional for Wake Word)
# Get yours at: https://console.picovoice.ai/
PORCUPINE_ACCESS_KEY=your_porcupine_key_here
